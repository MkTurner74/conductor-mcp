# Copy to .env for local development. Never commit .env to git.

# Required: contents of the API key file downloaded from dashboard.conductortech.com/profile
# Can be the raw JSON string {"api_key": "..."} or just the key value itself
CONDUCTOR_API_KEY=your_api_key_here

# Optional: override the Conductor API base URL (default is correct for most accounts)
CONDUCTOR_API_URL=https://api.conductortech.com
